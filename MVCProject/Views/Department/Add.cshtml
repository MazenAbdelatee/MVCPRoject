@model Department
@{
    ViewData["Title"] = "Add";
}
<div class="container mt-4">
    <h2>Add New Department</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            @* The form automatically posts to the Create action because of asp-action="Create" *@
            <form asp-action="Add" method="post">

                

                
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter department name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>


                <div class="form-group mb-3">
                    <label asp-for="MgrName" class="control-label fw-bold"></label>
                    <input asp-for="MgrName" class="form-control" placeholder="Enter department name" />
                    <span asp-validation-for="MgrName" class="text-danger"></span>
                </div>



                @* Buttons *@
                <div class="form-group">
                    <button type="submit" asp-action="SaveAdd" class="btn btn-success">Save Department</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

