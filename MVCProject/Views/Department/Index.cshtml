@model List<Department> 
@{
    ViewData["Title"]  =  "Departments" ;
}
<div class="container mt-4">
    <h2>Departments</h2>

    @* A helpful button to add a new department *@
    <p>
        <a asp-action="Add" class="btn btn-primary">Add New Department</a>
    </p>

    @* The table to display the data *@
    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Department Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @* 2. Loop through each department in the list passed from the controller *@
            @foreach (var dept in Model)
            {
                <tr>
                    <td>@dept.Id</td>
                    <td>@dept.Name</td>
                    <td>
                        @* 3. Standard Action Links for CRUD operations *@
                        <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="DepartmentDetail" asp-route-id="@dept.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="DeleteDept" asp-route-id="@dept.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>