@model List<Student>
@{
	ViewData["Title"] = "Index";
}

<table class="table table-hover table-bordered">
	<tr>
		<th>Number</th>
		<th>Name</th>
		<th>DepartmentId</th>
	</tr>
	@foreach (var item in Model)
	{
		<tr>
			<td>@item.Id</td>
			<td>@item.Name</td>
			<td>@item.DepartmentId</td>
		</tr>
	}
</table>
